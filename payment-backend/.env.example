PORT=8080
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Admin Auth — use one of these:
# 1) GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/service-account.json
# 2) FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# SafePay Configuration
# Environment: "sandbox" for testing, "production" for live
SAFEPAY_ENVIRONMENT=sandbox

# SafePay API Key (from SafePay Dashboard → Credentials)
SAFEPAY_API_KEY=your-safepay-api-key

# SafePay Secret Key (from SafePay Dashboard → Credentials)
SAFEPAY_SECRET_KEY=your-safepay-secret-key

# SafePay Webhook Secret (base64-encoded, from SafePay Dashboard → Webhooks)
SAFEPAY_WEBHOOK_SECRET=your-base64-encoded-webhook-secret

# Your backend's public base URL (used to build success/failure redirect URLs)
# Example: https://autiease-payment-backend.onrender.com
BACKEND_PUBLIC_BASE_URL=https://your-backend-domain.example.com

# Enable mock payment mode for local testing (skips SafePay API calls entirely)
PAYMENTS_MOCK_MODE=false

# Comma-separated origins (for web clients). Keep empty for open CORS.
# ALLOWED_ORIGINS=https://your-frontend.example.com,https://staging.example.com
