rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() && userDoc().role == 'admin';
    }

    function isParent() {
      return signedIn() && userDoc().role == 'parent';
    }

    function isTherapist() {
      return signedIn() && userDoc().role == 'therapist';
    }

    function ownsChild(childId) {
      return isParent() &&
        get(/databases/$(database)/documents/child_profiles/$(childId)).data.parentId == request.auth.uid;
    }

    function isThreadParticipant(threadData) {
      return signedIn() &&
        (threadData.parentId == request.auth.uid || threadData.therapistId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId &&
        (!('role' in request.resource.data) || request.resource.data.role != 'admin' || request.auth.token.email == 'admin@autiease.com');
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin()) &&
        (request.resource.data.role == resource.data.role || request.resource.data.role != 'admin' || request.auth.token.email == 'admin@autiease.com' || isAdmin());
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /child_profiles/{childId} {
      allow read: if (isParent() && resource.data.parentId == request.auth.uid) || isTherapist() || isAdmin();
      allow create: if isParent() && request.resource.data.parentId == request.auth.uid;
      allow update: if isParent() && request.resource.data.parentId == request.auth.uid &&
        request.resource.data.parentId == resource.data.parentId;
      allow delete: if isParent() && resource.data.parentId == request.auth.uid;
    }

    match /child_assignments/{childId} {
      allow read: if (isParent() && resource.data.parentId == request.auth.uid) || isTherapist();
      allow create: if isParent() && request.resource.data.parentId == request.auth.uid;
      allow update: if isParent() && request.resource.data.parentId == request.auth.uid &&
        request.resource.data.parentId == resource.data.parentId;
      allow delete: if isParent() && resource.data.parentId == request.auth.uid;
    }

    match /therapist_profiles/{therapistId} {
      allow read: if signedIn();
      allow create: if (isTherapist() && request.auth.uid == therapistId &&
        (!('verificationStatus' in request.resource.data) || request.resource.data.verificationStatus == 'pending') &&
        (!('verifiedBadge' in request.resource.data) || request.resource.data.verifiedBadge == false)) || isAdmin();
      allow update: if (isTherapist() && request.auth.uid == therapistId &&
        (!('verificationStatus' in request.resource.data) || request.resource.data.verificationStatus == resource.data.verificationStatus) &&
        (!('verifiedBadge' in request.resource.data) || request.resource.data.verifiedBadge == resource.data.verifiedBadge)) || isAdmin();
      allow delete: if signedIn() && request.auth.uid == therapistId;
    }

    match /content_categories/{document=**} {
      allow read: if signedIn();
    }

    match /content_items/{document=**} {
      allow read: if signedIn();
    }

    match /learning_modules/{document=**} {
      allow read: if signedIn();
    }

    match /daily_activity_templates/{document=**} {
      allow read: if signedIn();
    }

    match /dashboard_snapshots/{childId} {
      allow read: if ownsChild(childId) || isTherapist();
      allow create, update: if ownsChild(childId);
      allow delete: if ownsChild(childId);
    }

    match /mood_logs/{logId} {
      allow read: if signedIn();
      allow create: if isParent() && request.resource.data.parentId == request.auth.uid;
      allow delete: if isParent() && resource.data.parentId == request.auth.uid;
    }

    match /activity_progress/{progressId} {
      allow read: if signedIn();
      allow create: if signedIn() && ownsChild(request.resource.data.childId);
      allow delete: if ownsChild(resource.data.childId);
    }

    match /communication_sentence_settings/{childId}/items/{settingId} {
      allow read: if ownsChild(childId) || isTherapist();
      allow create, update: if ownsChild(childId) &&
        request.resource.data.childId == childId;
    }

    match /therapist_threads/{threadId} {
      allow read: if isThreadParticipant(resource.data);
      allow create: if isParent() &&
        request.resource.data.parentId == request.auth.uid &&
        ownsChild(request.resource.data.childId);
      // Participants may update thread-level metadata (typing status, lastRead
      // timestamps) but must not change the immutable identity fields.
      allow update: if isThreadParticipant(resource.data) &&
        request.resource.data.parentId == resource.data.parentId &&
        request.resource.data.therapistId == resource.data.therapistId &&
        request.resource.data.childId == resource.data.childId &&
        request.resource.data.subscriptionId == resource.data.subscriptionId;
      allow delete: if isParent() && resource.data.parentId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isThreadParticipant(
          get(/databases/$(database)/documents/therapist_threads/$(threadId)).data
        );
        allow create: if (
            isThreadParticipant(get(/databases/$(database)/documents/therapist_threads/$(threadId)).data) ||
            isThreadParticipant(getAfter(/databases/$(database)/documents/therapist_threads/$(threadId)).data)
          ) &&
          (
            (request.resource.data.senderId == request.auth.uid &&
             ((isParent() && request.resource.data.senderRole == 'parent') ||
              (isTherapist() && request.resource.data.senderRole == 'therapist')))
            ||
            (isParent() &&
             request.resource.data.body == "Hi! Thank you for subscribing to my support plan. Please tell me a bit about your child's goals so we can get started!" &&
             request.resource.data.senderRole == 'therapist')
          );
        // Participants can soft-delete their own messages (set isDeleted: true)
        allow update: if isThreadParticipant(
            get(/databases/$(database)/documents/therapist_threads/$(threadId)).data
          ) &&
          resource.data.senderId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['body', 'isDeleted']) &&
          request.resource.data.isDeleted == true;
        allow delete: if isParent() &&
          get(/databases/$(database)/documents/therapist_threads/$(threadId)).data.parentId == request.auth.uid;
      }
    }

    match /subscription_products/{document=**} {
      allow read: if signedIn();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if signedIn() && (resource == null || resource.data.userId == request.auth.uid || resource.data.therapistId == request.auth.uid || isAdmin());
      allow create, update: if false;
      allow delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /checkout_sessions/{sessionId} {
      allow read: if signedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /therapist_earnings/{earningId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || resource.data.therapistId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /withdrawal_requests/{requestId} {
      allow read: if signedIn() && (resource.data.therapistId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /legal_documents/{document=**} {
      allow read: if true;
    }

    match /app_modules/{document=**} {
      allow read: if signedIn();
    }

    match /settings_entries/{document=**} {
      allow read: if signedIn();
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /learning_metrics/{metricId} {
      allow create: if isParent() && ownsChild(request.resource.data.childId);
      allow read: if isTherapist();
      allow delete: if isParent() && ownsChild(resource.data.childId);
    }

    match /therapist_reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if isParent() && request.resource.data.parentId == request.auth.uid;
      allow update, delete: if isAdmin() || (signedIn() && resource.data.parentId == request.auth.uid);
    }

    match /cancellation_analytics/{analyticsId} {
      allow create: if signedIn() && request.resource.data.parentId == request.auth.uid;
      allow read: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if signedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /admin_audit_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // Platform revenue summary — backend writes via Admin SDK (bypasses rules)
    // Admins can read; no client-side writes allowed.
    match /platform_revenue/{document=**} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Payment events — idempotency store. Backend writes via Admin SDK only.
    match /payment_events/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() && (
        isAdmin() ||
        request.resource.data.userId == request.auth.uid ||
        (isParent() &&
         request.resource.data.category == 'reviews' &&
         request.resource.data.title == '📅 New Connection Request!' &&
         request.resource.data.isRead == false)
      );
      allow delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
