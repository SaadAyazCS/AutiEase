rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() && userDoc().role == 'admin';
    }

    function isParent() {
      return signedIn() && userDoc().role == 'parent';
    }

    function isTherapist() {
      return signedIn() && userDoc().role == 'therapist';
    }

    // ownsChild: used for reads and writes where child_profiles already exist
    function ownsChild(childId) {
      return isParent() &&
        get(/databases/$(database)/documents/child_profiles/$(childId)).data.parentId == request.auth.uid;
    }

    // ownsChildAfter: used during batch writes where child_profiles is in the
    // same batch (e.g., initial signup that creates child + dashboard together)
    function ownsChildAfter(childId) {
      return isParent() &&
        getAfter(/databases/$(database)/documents/child_profiles/$(childId)).data.parentId == request.auth.uid;
    }

    function isThreadParticipant(threadData) {
      return signedIn() &&
        (threadData.parentId == request.auth.uid || threadData.therapistId == request.auth.uid);
    }

    function isPackageValid(pkg) {
      return !(pkg is map) ||
        ((!('price' in pkg) || (pkg.price >= 0 && pkg.price <= 1000000)) &&
         (!('durationMinutes' in pkg) || (pkg.durationMinutes >= 1 && pkg.durationMinutes <= 480)) &&
         (!('sessionsPerWeek' in pkg) || (pkg.sessionsPerWeek >= 1 && pkg.sessionsPerWeek <= 21)));
    }

    function arePackagesValid(packages) {
      return packages == null ||
        !(packages is list) ||
        packages.size() == 0 ||
        ((packages.size() >= 1 ? isPackageValid(packages[0]) : true) &&
         (packages.size() >= 2 ? isPackageValid(packages[1]) : true) &&
         (packages.size() >= 3 ? isPackageValid(packages[2]) : true) &&
         (packages.size() >= 4 ? isPackageValid(packages[3]) : true) &&
         (packages.size() >= 5 ? isPackageValid(packages[4]) : true));
    }

    function arePackagesLimitValid(requestData, resourceData) {
      return !('servicePackages' in requestData) ||
        (resourceData != null && 'servicePackages' in resourceData && requestData.servicePackages.size() <= resourceData.servicePackages.size()) ||
        requestData.servicePackages.size() <= requestData.get('specializations', (resourceData != null && 'specializations' in resourceData) ? resourceData.specializations : []).size();
    }



    match /users/{userId} {
      allow read: if signedIn();
      // Users can write to their own document.
      // They cannot grant themselves the admin role unless they are the
      // designated admin email. We deliberately avoid calling isAdmin() here
      // because it reads this same document, which can cause rule evaluation
      // to fail when the document is being created for the first time.
      allow create: if signedIn() && request.auth.uid == userId &&
          request.resource.data.get('role', '') != 'admin';
      allow update: if signedIn() && request.auth.uid == userId &&
          request.resource.data.get('role', '') != 'admin';
      // Allow admin to set/update any user document
      allow create, update: if signedIn() && (
        request.auth.token.email == 'admin@autiease.com' || isAdmin()
      );
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /child_profiles/{childId} {
      allow read: if (isParent() && resource.data.parentId == request.auth.uid) || isTherapist() || isAdmin();
      allow create: if isParent() && request.resource.data.parentId == request.auth.uid &&
        (!('childName' in request.resource.data) || request.resource.data.childName.size() <= 50);
      allow update: if isParent() && request.resource.data.parentId == request.auth.uid &&
        request.resource.data.parentId == resource.data.parentId &&
        (!('childName' in request.resource.data) || request.resource.data.childName.size() <= 50);
      allow delete: if isParent() && resource.data.parentId == request.auth.uid;
    }

    match /child_assignments/{childId} {
      allow read: if (isParent() && resource.data.parentId == request.auth.uid) || isTherapist();
      allow create: if isParent() && request.resource.data.parentId == request.auth.uid &&
        (!('childName' in request.resource.data) || request.resource.data.childName.size() <= 50);
      allow update: if isParent() && request.resource.data.parentId == request.auth.uid &&
        request.resource.data.parentId == resource.data.parentId &&
        (!('childName' in request.resource.data) || request.resource.data.childName.size() <= 50);
      allow delete: if isParent() && resource.data.parentId == request.auth.uid;
    }

    match /therapist_profiles/{therapistId} {
      allow read: if signedIn();
      allow create: if (isTherapist() && request.auth.uid == therapistId &&
        (!('verificationStatus' in request.resource.data) || request.resource.data.verificationStatus == 'pending') &&
        (!('verifiedBadge' in request.resource.data) || request.resource.data.verifiedBadge == false) &&
        (!('bio' in request.resource.data) || request.resource.data.bio.size() <= 1000) &&
        (!('servicePackages' in request.resource.data) || (arePackagesValid(request.resource.data.servicePackages) && arePackagesLimitValid(request.resource.data, null))) &&
        (!('isAcceptingClients' in request.resource.data) || request.resource.data.isAcceptingClients is bool)) || isAdmin();
      allow update: if (isTherapist() && request.auth.uid == therapistId &&
        (!('verificationStatus' in request.resource.data) || 
         request.resource.data.verificationStatus == resource.data.verificationStatus ||
         (resource.data.verificationStatus == 'rejected' && request.resource.data.verificationStatus == 'pending') ||
         (resource.data.verificationStatus == 'restricted' && request.resource.data.verificationStatus == 'approved' && request.time > resource.data.restrictionUntil)
        ) &&
        (!('verifiedBadge' in request.resource.data) || request.resource.data.verifiedBadge == resource.data.verifiedBadge) &&
        (!('bio' in request.resource.data) || request.resource.data.bio.size() <= 1000) &&
        (!('servicePackages' in request.resource.data) || (arePackagesValid(request.resource.data.servicePackages) && arePackagesLimitValid(request.resource.data, resource.data))) &&
        (!('isAcceptingClients' in request.resource.data) || request.resource.data.isAcceptingClients is bool)) ||
        (isParent() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'totalReviews', 'ratingBreakdown', 'updatedAt'])) ||
        isAdmin();
      allow delete: if signedIn() && request.auth.uid == therapistId;
    }

    match /therapist_verification_evidence/{therapistId} {
      allow read, write: if isAdmin();
    }

    match /therapist_profile_updates/{updateId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.therapistId == request.auth.uid;
      allow update: if signedIn() && (
        (request.auth.uid == resource.data.therapistId && request.resource.data.therapistId == resource.data.therapistId && request.resource.data.status in ['pending_acknowledgment', 'pending_review']) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /content_categories/{document=**} {
      allow read: if signedIn();
    }

    match /content_items/{document=**} {
      allow read: if signedIn();
    }

    match /learning_modules/{document=**} {
      allow read: if signedIn();
    }

    match /daily_activity_templates/{document=**} {
      allow read: if signedIn();
    }

    match /dashboard_snapshots/{childId} {
      allow read: if ownsChild(childId) || isTherapist();
      // During initial signup the child_profile and snapshot are written in the
      // same batch, so use getAfter() to see the not-yet-committed child doc.
      allow create, update: if ownsChildAfter(childId);
      allow delete: if ownsChild(childId);
    }

    match /mood_logs/{logId} {
      allow read: if signedIn();
      allow create: if isParent() && request.resource.data.parentId == request.auth.uid;
      allow delete: if isParent() && resource.data.parentId == request.auth.uid;
    }

    match /activity_progress/{progressId} {
      allow read: if signedIn();
      allow create: if signedIn() && ownsChild(request.resource.data.childId);
      allow delete: if ownsChild(resource.data.childId);
    }

    match /communication_sentence_settings/{childId}/items/{settingId} {
      allow read: if ownsChild(childId) || isTherapist();
      allow create, update: if ownsChild(childId) &&
        request.resource.data.childId == childId;
    }

    match /therapist_threads/{threadId} {
      allow read: if isThreadParticipant(resource.data);
      allow create: if isParent() &&
        request.resource.data.parentId == request.auth.uid &&
        ownsChild(request.resource.data.childId);
      // Participants may update thread-level metadata (typing status, lastRead
      // timestamps) but must not change the immutable identity fields.
      // Admins may update any thread (e.g., to lock/unlock after resolving a report).
      allow update: if isAdmin() || (
        isThreadParticipant(resource.data) &&
        request.resource.data.parentId == resource.data.parentId &&
        request.resource.data.therapistId == resource.data.therapistId &&
        request.resource.data.childId == resource.data.childId &&
        request.resource.data.subscriptionId == resource.data.subscriptionId &&
        // Prevent altering the original creation timestamp
        (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt)
      );
      // Parent or therapist may delete their own thread (e.g., after report / subscription cancellation)
      allow delete: if isAdmin() ||
        (isParent() && resource.data.parentId == request.auth.uid) ||
        (isTherapist() && resource.data.therapistId == request.auth.uid);

      match /messages/{messageId} {
        allow read: if isThreadParticipant(
          get(/databases/$(database)/documents/therapist_threads/$(threadId)).data
        );
        allow create: if (
            isThreadParticipant(get(/databases/$(database)/documents/therapist_threads/$(threadId)).data) ||
            isThreadParticipant(getAfter(/databases/$(database)/documents/therapist_threads/$(threadId)).data)
          ) &&
          (
            (request.resource.data.senderId == request.auth.uid &&
             ((isParent() && request.resource.data.senderRole == 'parent') ||
              (isTherapist() && request.resource.data.senderRole == 'therapist')))
            ||
            (isParent() &&
             request.resource.data.body == "Hi! Thank you for subscribing to my support plan. Please tell me a bit about your child's goals so we can get started!" &&
             request.resource.data.senderRole == 'therapist')
          );
        // Participants can soft-delete their own messages (isDeleted: false -> true only)
        allow update: if isThreadParticipant(
            get(/databases/$(database)/documents/therapist_threads/$(threadId)).data
          ) &&
          resource.data.senderId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['body', 'isDeleted']) &&
          request.resource.data.isDeleted == true &&
          // Prevent un-deleting a message
          resource.data.isDeleted != true;
        // Parent, therapist (for chat deletion after report), or admin may hard-delete messages
        allow delete: if isAdmin() ||
          (isParent() && get(/databases/$(database)/documents/therapist_threads/$(threadId)).data.parentId == request.auth.uid) ||
          (isTherapist() && get(/databases/$(database)/documents/therapist_threads/$(threadId)).data.therapistId == request.auth.uid);
      }
    }

    match /subscription_products/{document=**} {
      allow read: if signedIn();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if signedIn() && (resource == null || resource.data.userId == request.auth.uid || resource.data.therapistId == request.auth.uid || isAdmin());
      allow create, update: if signedIn() && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource.data.userId == request.auth.uid) ||
        isAdmin()
      );
      allow delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /checkout_sessions/{sessionId} {
      allow read: if signedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /therapist_earnings/{earningId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || resource.data.therapistId == request.auth.uid || isAdmin());
      allow create: if false;
      allow update, delete: if isAdmin();
    }


    match /withdrawal_requests/{requestId} {
      allow read: if signedIn() && (resource.data.therapistId == request.auth.uid || isAdmin());
      // Therapists create their own withdrawal requests via the backend
      allow create: if false;
      // Admin can update (mark paid / reject) and delete withdrawal requests
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /wallet_ledger/{ledgerId} {
      allow read: if signedIn() && (resource.data.therapistId == request.auth.uid || isAdmin());
      // Admin can create ledger entries (e.g., reversal records on rejection)
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /legal_documents/{document=**} {
      allow read: if true;
    }

    match /app_modules/{document=**} {
      allow read: if signedIn();
    }

    match /settings_entries/{document=**} {
      allow read: if signedIn();
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid &&
        request.resource.data.feedback.size() <= 500;
      allow read: if isAdmin();
      allow delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /learning_metrics/{metricId} {
      allow create: if isParent() && ownsChild(request.resource.data.childId);
      allow read: if isTherapist();
      allow delete: if isParent() && ownsChild(resource.data.childId);
    }

    match /therapist_reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if isParent() && request.resource.data.parentId == request.auth.uid &&
        (!('feedback' in request.resource.data) || request.resource.data.feedback.size() <= 300) &&
        (!('privateFeedback' in request.resource.data) || request.resource.data.privateFeedback.size() <= 300);
      allow update: if isAdmin() || (signedIn() && resource.data.parentId == request.auth.uid &&
                                     request.resource.data.parentId == resource.data.parentId &&
                                     request.resource.data.therapistId == resource.data.therapistId);
      allow delete: if isAdmin() || (signedIn() && resource.data.parentId == request.auth.uid);
    }

    match /cancellation_analytics/{analyticsId} {
      allow create: if signedIn() && request.resource.data.parentId == request.auth.uid;
      allow read: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if signedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /admin_audit_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // Platform revenue summary — backend writes via Admin SDK (bypasses rules)
    // Admins can read; no client-side writes allowed.
    match /platform_revenue/{document=**} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Payment events — idempotency store. Backend writes via Admin SDK only.
    match /payment_events/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() && (
        isAdmin() ||
        request.resource.data.userId == request.auth.uid ||
        (request.resource.data.isRead == false && (
          request.resource.data.category == 'messages' ||
          request.resource.data.category == 'reviews' ||
          request.resource.data.category == 'appointments' ||
          request.resource.data.category == 'subscription' ||
          request.resource.data.category == 'activities' ||
          request.resource.data.category == 'reports' ||
          request.resource.data.category == 'emergency' ||
          request.resource.data.category == 'wallet'
        ))
      );
      allow delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /clinical_notes/{noteId} {
      allow read: if signedIn() && (
        resource.data.therapistId == request.auth.uid ||
        resource.data.parentId == request.auth.uid ||
        ownsChild(resource.data.childId) ||
        isAdmin()
      );
      allow create: if isTherapist() && request.resource.data.therapistId == request.auth.uid;
      allow update: if isTherapist() && resource.data.therapistId == request.auth.uid &&
        request.resource.data.therapistId == resource.data.therapistId &&
        request.resource.data.parentId == resource.data.parentId &&
        request.resource.data.childId == resource.data.childId;
      allow delete: if isTherapist() && resource.data.therapistId == request.auth.uid;
    }

    match /appointment_slots/{slotId} {
      allow read: if signedIn();
      allow create: if isTherapist() && request.resource.data.therapistId == request.auth.uid;
      allow delete: if isTherapist() && resource.data.therapistId == request.auth.uid;
      allow update: if signedIn() &&
        request.resource.data.therapistId == resource.data.therapistId && (
          (isTherapist() && resource.data.therapistId == request.auth.uid) ||
          (isParent() &&
           request.resource.data.dateTime == resource.data.dateTime &&
           request.resource.data.durationMinutes == resource.data.durationMinutes && (
             // Case 1: Booking an available slot
             (resource.data.status == 'available' &&
              request.resource.data.status == 'booked' &&
              request.resource.data.bookedByParentId == request.auth.uid) ||
             // Case 2: Canceling or updating their own booking
             (resource.data.status == 'booked' &&
              resource.data.bookedByParentId == request.auth.uid && (
                // Released back to available
                (request.resource.data.status == 'available' &&
                 request.resource.data.get('bookedByParentId', null) == null) ||
                // Cancelled status
                request.resource.data.status == 'cancelled' ||
                // Or keeping it booked by themselves (just changing notes/child details)
                request.resource.data.bookedByParentId == request.auth.uid
              ))
           ))
        );
    }
  }
}
