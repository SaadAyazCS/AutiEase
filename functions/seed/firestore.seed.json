  "legal_documents": [
    {
      "id": "parent-terms",
      "audience": "parent",
      "version": "1.0.0",
      "title": "Parent Terms & Conditions",
      "body": "By using AutiEase as a parent or caregiver, you agree to manage child profiles responsibly, review assigned learning content, and supervise child usage. All child content selections, therapist access, and notifications are controlled by the parent account.",
      "isActive": true
    },
    {
      "id": "therapist-terms",
      "audience": "therapist",
      "version": "1.0.0",
      "title": "Therapist Terms & Conditions",
      "body": "Therapists on AutiEase must maintain valid professional standing, communicate ethically, and use the platform only for legitimate support and educational guidance. Therapist access to child-facing plans is read-only in v1; assignment authority remains with the parent.",
      "isActive": true
    },
    {
      "id": "about-app",
      "audience": "all",
      "version": "1.0.0",
      "title": "About AutiEase",
      "body": "AutiEase is a structured support app for autistic children and their caregivers. The platform combines assigned communication topics, learning modules, daily activities, progress tracking, therapist support, and subscription-based professional guidance in one place. All product content shown in the app is designed to be delivered from Firestore rather than hardcoded in the client.",
      "isActive": true
    }
  ],
